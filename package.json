{
    "name": "chatbot-backend",
    "version": "1.0.0",
    "description": "NGD Chatbot Backend — Node.js + Express + SQLite FTS5",
    "main": "dist/app.cjs",
    "scripts": {
        "start": "node src/app.js",
        "dev": "nodemon src/app.js",
        "build": "node scripts/build.js",
        "build:plain": "OBFUSCATE_BUILD=false node scripts/build.js",
        "start:dist": "node dist/app.cjs",
        "export:interactions": "node scripts/exportInteractionsToCsv.js",
        "validate:interactions": "node scripts/validateInteractionLog.js"
    },
    "dependencies": {
        "better-sqlite3": "^11.0.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "express": "^4.18.0",
        "express-rate-limit": "^7.0.0",
        "helmet": "^7.0.0"
    },
    "devDependencies": {
        "esbuild": "^0.28.0",
        "javascript-obfuscator": "^5.4.2",
        "nodemon": "^3.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
